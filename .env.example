# Pika AI Assistant — Environment Variables
# Copy this file to .env and add your API keys.
# ALL keys are OPTIONAL — Pika runs in demo mode without them.

# === Free LLM Provider API Keys ===
# Groq (fastest, recommended) — https://console.groq.com
GROQ_API_KEY=

# Cerebras (ultra-fast) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=

# DeepSeek (coding) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenRouter (20+ free models) — https://openrouter.ai
OPENROUTER_API_KEY=

# Z.ai (GLM) — https://chat.z.ai
ZAI_API_KEY=

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=

# === Optional defaults ===
# DEFAULT_WEATHER_LOCATION=Delhi
